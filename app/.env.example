# Copy to apps/agent/.env and fill in what you use. All keys are optional.

# Model providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_API_KEY=
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=

# Groq model ids (used when GROQ_API_KEY is set)
GROQ_LARGE_MODEL=llama-3.3-70b-versatile
GROQ_SMALL_MODEL=llama-3.1-8b-instant

# Walrus (testnet). Signer absent -> read-only. Never commit a real key.
WALRUS_NETWORK=testnet
WALRUS_EPOCHS=3
SUI_RPC_URL=
WALRUS_SIGNER_KEY=
MEMWAL_SESSION_TURN_LIMIT=

# Seal (job-result encryption). Empty -> defaults / write skipped.
SEAL_PACKAGE_ID=
SEAL_KEY_SERVER_IDS=
SEAL_THRESHOLD=

# Inbound HTTP endpoint (GET /ping liveness, POST /chat when run via `npm run serve`). The web
# "Register agent" flow pings /ping; the dashboard chat routes users to /chat. Bind 0.0.0.0 so the
# web can reach it; expose AGENT_PORT publicly.
AGENT_PORT=3939
AGENT_HOST=0.0.0.0
# Public URL this agent is reachable at. `npm run serve` self-publishes it to the data gateway so
# the web can discover + chat with this agent. Leave blank to disable discovery.
AGENT_PUBLIC_URL=

# Quadra services the agent signs requests to (job lifecycle). Defaults are the local
# dev ports. The signing key's address must be a REGISTERED agent on-chain.
INTAKE_URL=http://localhost:5000
DATA_GATEWAY_URL=http://localhost:8787
# Auth key for intake + gateway. Absent -> falls back to WALRUS_SIGNER_KEY. Never commit a real key.
AGENT_SECRET_KEY=
# The agent decides whether to accept a job and quotes the cost in conversation (developer
# rules go in the character's system prompt). No cost env. TEST_TEMPLATE_ID only scopes the
# live auth smoke test to a seeded data-layer template id.
TEST_TEMPLATE_ID=

# Competition mode (FREE jobs from the competition engine). Off by default. When on (and a usable
# signer is present) the agent connects the competition socket and does competition jobs for free
# ALONGSIDE the paid lifecycle. Set COMPETITION_ID to auto-join one at startup, or use /join <id>.
COMPETITION_ENABLED=false
COMPETITION_URL=http://localhost:5100
# COMPETITION_SOCKET_URL defaults to COMPETITION_URL.
COMPETITION_SOCKET_URL=
COMPETITION_ID=
# Needed to build the on-chain join_competition call (the published quadra package + agent
# registry). QUADRA_PACKAGE_ID falls back to SEAL_PACKAGE_ID (the same published package).
QUADRA_PACKAGE_ID=
AGENT_REGISTRY_ID=
