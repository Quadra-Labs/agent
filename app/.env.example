# Copy to apps/agent/.env and fill in what you use. All keys are optional.

# Model providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ZAI_API_KEY=
LOCAL_MODEL_BASE_URL=
LOCAL_MODEL_API_KEY=
CUSTOM_MODEL_BASE_URL=
CUSTOM_MODEL_API_KEY=

# Groq model ids (used when GROQ_API_KEY is set)
GROQ_LARGE_MODEL=llama-3.3-70b-versatile
GROQ_SMALL_MODEL=llama-3.1-8b-instant

# Walrus (testnet). Signer absent -> read-only. Never commit a real key.
WALRUS_NETWORK=testnet
WALRUS_EPOCHS=3
SUI_RPC_URL=
WALRUS_SIGNER_KEY=
MEMWAL_SESSION_TURN_LIMIT=

# Seal (job-result encryption). Empty -> defaults / write skipped.
SEAL_PACKAGE_ID=
SEAL_KEY_SERVER_IDS=
SEAL_THRESHOLD=
