{
  "name": "@sui-walrus/plugin-memwal",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ElizaOS plugin: checkpoint a chat session as a blob on Walrus, with a pluggable encrypt/decrypt seam.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "tsx --test test/**/*.test.ts"
  },
  "dependencies": {
    "@elizaos/core": "^1.7.2",
    "@mysten/sui": "^2.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
