# The demo needs ONLY a Groq API key. No Sui wallet, no private key, nothing else.
# Walrus writes are sponsored by the public testnet publisher (wallet-free). There is
# NO local fallback: if the public Walrus testnet is unreachable the demo fails loudly.

# Required: your Groq API key (https://console.groq.com/keys).
GROQ_API_KEY=gsk_your_key_here

# Model overrides. plugin-groq's built-in default large model is DECOMMISSIONED by
# Groq (HTTP 400), so these overrides are REQUIRED for the LLM step to work.
GROQ_LARGE_MODEL=llama-3.3-70b-versatile
GROQ_SMALL_MODEL=llama-3.1-8b-instant

# Optional: override the public Walrus testnet HTTP endpoints. Defaults shown.
# WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
# WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
