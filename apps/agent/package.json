{
  "name": "@sui-walrus/agent",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "ElizaOS agent app: boots the runtime with all four plugins (sql, groq, walrus, memwal) live.",
  "scripts": {
    "boot": "tsx src/boot.ts",
    "roundtrip": "tsx src/roundtrip.ts",
    "chat:proof": "tsx src/chatProof.ts",
    "close:proof": "tsx src/closeProof.ts",
    "recall:proof": "tsx src/recallProof.ts",
    "e2e:proof": "tsx src/e2eProof.ts",
    "match:proof": "tsx src/matchProof.ts",
    "test:all": "npm run boot && npm run roundtrip && npm run chat:proof && npm run close:proof && npm run recall:proof && npm run e2e:proof && npm run match:proof",
    "test": "npm run test:all",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@elizaos/core": "^1.7.2",
    "@elizaos/plugin-groq": "^1.0.4",
    "@elizaos/plugin-sql": "^1.7.2",
    "@mysten/sui": "2.17.0",
    "@mysten/walrus": "1.1.7",
    "@sui-walrus/plugin-walrus": "file:../../plugins/plugin-walrus",
    "@sui-walrus/plugin-memwal": "file:../../plugins/plugin-memwal"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
