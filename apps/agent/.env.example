# apps/agent configuration. Copy to apps/agent/.env and fill in.
# These values are loaded into process.env at boot, then flow into
# character.settings (NOT read from process.env directly by plugins).
#
# INTERACTIVE CHAT (use the app like a real user):
#   npm run chat                          # default WalrusAgent identity
#   npm run chat -- --list                # list available characters and exit
#   npm run chat -- --character example   # load characters/example.md
#   npm run chat -- --user alice --character example
# The chat CLI REQUIRES both GROQ_API_KEY and a funded WALRUS_SIGNER_KEY (so /close
# writes a live checkpoint). In-chat commands: /close /resume /help /exit. Resume a
# prior session by re-launching with the SAME --user and --character.
# Define your own agent in apps/agent/characters/ as Markdown (friendlier) OR JSON:
#   Markdown (characters/example.md): YAML frontmatter (name, optional bio,
#     optional templateCategoryIds) + a body that becomes the systemPrompt.
#   JSON (characters/example.json): { "name", "bio"[], "systemPrompt"?, "templateCategoryIds"?[] }
# A bare --character <name> finds <name>.md if present, else <name>.json.

# --- Groq LLM (required to actually chat; boot.ts uses a placeholder if absent) ---
GROQ_API_KEY=
GROQ_LARGE_MODEL=llama-3.3-70b-versatile
GROQ_SMALL_MODEL=llama-3.1-8b-instant

# --- Walrus (A3 SDK path with a funded testnet signer) ---
# network must be "testnet"; the service derives the testnet RPC if SUI_RPC_URL is blank.
WALRUS_NETWORK=testnet
# SUI_RPC_URL=
WALRUS_EPOCHS=3
# OPTIONAL funded Sui testnet signer secret (suiprivkey1... or base64 32-byte seed).
# Absent -> Walrus boots READ-ONLY (store() returns config_error). NEVER commit a real key.
# The live checkpoint round-trip (npm run roundtrip) needs a FUNDED testnet key:
# without it the round-trip SKIPS cleanly (non-failure); with it, it stores+reads
# a real blob on Walrus and asserts the round-trip.
# WALRUS_SIGNER_KEY=

# --- MemWal checkpoint writer (A3 Task 4) ---
# Session-length checkpoint gate: once a session reaches this many turns, the
# session-lifecycle caller rolls it into a checkpoint. This is a SESSION-LIFECYCLE
# decision, NOT a per-message evaluator (a per-message write would store a blob per
# turn and burn gas). Positive integer; defaults to 20 if unset/invalid.
# MEMWAL_SESSION_TURN_LIMIT=20

# --- Seal job-result write (writes the FINISHED job result, encrypted, to Walrus) ---
# When a job is done, the agent produces the real result, Seal-encrypts it under the
# job_id, and stores the ciphertext on Walrus. The Seal identity is the UTF-8 job_id, so
# decryption is governed by the on-chain quadra::job_access policy (user / agent /
# scheduler). See contracts/sources/job_access.move and src/jobResult.ts.
#
# SEAL_PACKAGE_ID is the deployed `quadra` Move package id (0x...). It is REQUIRED to
# encrypt: absent -> the result write is SKIPPED with a typed config_error (the Intake
# notification is still constructed). The contracts are not yet published (Move.toml has
# quadra = "0x0"); set this once the package is deployed to enable the live write.
# SEAL_PACKAGE_ID=
# Open-mode testnet key servers (comma-separated object ids). Defaults to the P0c spike
# pair; override only to point at different servers.
# SEAL_KEY_SERVER_IDS=0xb012378c9f3799fb5b1a7083da74a4069e3c3f1c93de0b27212a5799ce1e1e98,0x73d05d62c18d9374e3ea529e8e0ed6161da1a141a94d3f76ae3fe4e99356db75
# TSS threshold: how many key servers must return a key share. Defaults to 1.
# SEAL_THRESHOLD=1
