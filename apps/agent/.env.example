# apps/agent configuration. Copy to apps/agent/.env and fill in.
# These values are loaded into process.env at boot, then flow into
# character.settings (NOT read from process.env directly by plugins).

# --- Groq LLM (required to actually chat; boot.ts uses a placeholder if absent) ---
GROQ_API_KEY=
GROQ_LARGE_MODEL=llama-3.3-70b-versatile
GROQ_SMALL_MODEL=llama-3.1-8b-instant

# --- Walrus (A3 SDK path with a funded testnet signer) ---
# network must be "testnet"; the service derives the testnet RPC if SUI_RPC_URL is blank.
WALRUS_NETWORK=testnet
# SUI_RPC_URL=
WALRUS_EPOCHS=3
# OPTIONAL funded Sui testnet signer secret (suiprivkey1... or base64 32-byte seed).
# Absent -> Walrus boots READ-ONLY (store() returns config_error). NEVER commit a real key.
# The live checkpoint round-trip (npm run roundtrip) needs a FUNDED testnet key:
# without it the round-trip SKIPS cleanly (non-failure); with it, it stores+reads
# a real blob on Walrus and asserts the round-trip.
# WALRUS_SIGNER_KEY=

# --- MemWal checkpoint writer (A3 Task 4) ---
# Session-length checkpoint gate: once a session reaches this many turns, the
# session-lifecycle caller rolls it into a checkpoint. This is a SESSION-LIFECYCLE
# decision, NOT a per-message evaluator (a per-message write would store a blob per
# turn and burn gas). Positive integer; defaults to 20 if unset/invalid.
# MEMWAL_SESSION_TURN_LIMIT=20
